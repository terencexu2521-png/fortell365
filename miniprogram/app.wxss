page {
  background: #faf8ff;
  color: #1e1b4b;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 32rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #8b5cf6, #6d28d9);
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(109, 40, 217, 0.25);
}

.btn-secondary {
  background: #fff;
  color: #6d28d9;
  border: 2rpx solid #c4b5fd;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.btn-primary[disabled],
.btn-secondary[disabled] {
  opacity: 0.5;
}

.label {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.field {
  margin-bottom: 24rpx;
}

.pillar-grid {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.pillar-item {
  flex: 1;
  text-align: center;
  background: #faf8f5;
  border-radius: 12rpx;
  padding: 20rpx 8rpx;
}

.pillar-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.pillar-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.md-h2 {
  font-size: 32rpx;
  font-weight: 600;
  margin: 24rpx 0 12rpx;
  color: #1a1a2e;
}

.md-h3 {
  font-size: 28rpx;
  font-weight: 600;
  margin: 16rpx 0 8rpx;
  color: #333;
}

.md-p {
  margin-bottom: 12rpx;
}

.md-quote {
  color: #666;
  border-left: 6rpx solid #c4a882;
  padding-left: 16rpx;
  margin: 12rpx 0;
}

.md-line {
  font-size: 24rpx;
  color: #555;
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}
