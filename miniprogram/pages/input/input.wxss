.form-head .subtitle {
  margin-bottom: 0;
}

.field-input,
.picker-box {
  background: #faf7ff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-top: 8rpx;
}

.radio-row {
  display: flex;
  gap: 40rpx;
  margin-top: 8rpx;
}

.radio-item {
  display: flex;
  align-items: center;
}

.picker-hint {
  font-size: 22rpx;
  color: #94a3b8;
}

.location-tip {
  font-size: 22rpx;
  color: #7c3aed;
  background: #f5f3ff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-top: 8rpx;
}
