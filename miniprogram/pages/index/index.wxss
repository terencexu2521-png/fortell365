.home-page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 32rpx) 32rpx 48rpx;
  background: linear-gradient(165deg, #1e1035 0%, #2d1b4e 38%, #f8f4ff 38%, #faf8ff 100%);
}

.hero {
  padding: 48rpx 8rpx 40rpx;
  color: #fff;
}

.hero-badge {
  display: inline-block;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  padding: 8rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  border-radius: 999rpx;
  margin-bottom: 24rpx;
  color: #e9d5ff;
}

.hero-title {
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
}

.hero-subtitle {
  font-size: 34rpx;
  margin-top: 12rpx;
  color: #ddd6fe;
  letter-spacing: 2rpx;
}

.hero-desc {
  margin-top: 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.82);
  max-width: 90%;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 28rpx;
}

.tag {
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(139, 92, 246, 0.35);
  color: #f5f3ff;
}

.feature-card {
  margin-top: -8rpx;
}

.feature-item {
  display: flex;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.feature-item:last-child {
  margin-bottom: 0;
}

.feature-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #a78bfa, #7c3aed);
  margin-top: 10rpx;
  flex-shrink: 0;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #312e81;
}

.feature-text {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 6rpx;
}

.privacy-card .privacy-text {
  margin-bottom: 16rpx;
}

.agree-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #475569;
}

.hero-btn {
  margin-top: 8rpx;
}

.btn-ghost {
  margin-top: 16rpx;
  background: transparent;
  color: #6d28d9;
  border: none;
  font-size: 28rpx;
}

.btn-ghost::after {
  border: none;
}

.footer-note {
  text-align: center;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 32rpx;
}
